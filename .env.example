# Root-level variables consumed by docker-compose.yml interpolation.
# Copy to .env and fill with local values before running docker compose.

POSTGRES_PASSWORD=change-me-postgres-password
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# AES-256 service-level encryption key — used to encrypt TOTP secrets at rest in auth-service.
# Generate with: openssl rand -base64 32
SERVICE_ENCRYPTION_KEY=change-me-generate-with-openssl-rand-base64-32
