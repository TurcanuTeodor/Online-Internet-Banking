@startuml Transfer_Flow
!theme plain
skinparam backgroundColor white
skinparam defaultFontName "Segoe UI"
skinparam sequenceMessageAlign center

title Figure 4.5 — Transfer Flow Sequence

actor "User" as USER
participant "Frontend\n(React)" as FE
participant "API Gateway\n:8443" as GW
participant "Account Service\n:8083" as ACC
participant "Fraud Service\n:8086" as FRAUD
participant "Transaction Service\n:8084" as TX

== Transfer Initiation ==
USER -> FE : Click "Transfer"\n(fromIban, toIban, amount)
FE -> GW : POST /api/accounts/transfer\n[Authorization: Bearer <JWT>]
GW -> GW : JwtAuthFilter:\nvalidate signature + expiry
GW -> ACC : Forward request\n+ JWT header

== Validation ==
ACC -> ACC : Validate accounts exist
ACC -> ACC : Check ownership\n(JWT clientId == account clientId)
ACC -> ACC : Check sufficient balance

== Fraud Check (Synchronous — Tier 1) ==
ACC -> FRAUD : POST /api/internal/fraud/evaluate\n[X-Internal-Api-Secret]\n{accountId, clientId, amount,\nsenderIban, receiverIban,\naccountAgeDays, selfTransfer}

FRAUD -> FRAUD : Tier 1 Rule Engine:\n- LARGE_AMOUNT (>10,000)?\n- BURST (5+ tx/min)?\n- NEW_ACCOUNT + HIGH_AMOUNT?

alt Tier 1: BLOCK
  FRAUD --> ACC : {status: "BLOCK",\nexplanation: "..."}
  ACC --> GW : 422 BusinessRuleViolation
  GW --> FE : Error response
  FE --> USER : "Transaction blocked"
else Tier 1: ALLOW / REVIEW
  FRAUD --> ACC : {status: "ALLOW"}\nor {status: "MANUAL_REVIEW"}
end

== Balance Update ==
ACC -> ACC : sender.balance -= amount
ACC -> ACC : receiver.balance += convertedAmount\n(FX conversion if currencies differ)
ACC -> ACC : Save both accounts (@Transactional)

== Transaction Records ==
ACC -> TX : POST /api/transactions\n[JWT forwarded]\n{sender debit, sign: "-"}
TX --> ACC : 201 Created

ACC -> TX : POST /api/transactions\n[JWT forwarded]\n{receiver credit, sign: "+"}
TX --> ACC : 201 Created

ACC --> GW : 200 OK
GW --> FE : Transfer successful
FE --> USER : "Transfer complete"

@enduml
